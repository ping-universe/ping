    "express": "^4.21.0",
    "firebase-admin": "^12.7.0",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.17",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.15.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
