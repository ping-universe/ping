# Server
PORT=3000
NODE_ENV=development
BASE_URL=https://xxxx.ngrok.io

# Google Chat App
GOOGLE_PROJECT_ID=
GOOGLE_CHAT_SERVICE_ACCOUNT_KEY_PATH=./keys/chat-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=./keys/chat-service-account.json

# Atlassian OAuth (Jira + Confluence 공통)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=https://xxxx.ngrok.io/auth/atlassian/callback

# Gmail OAuth (GCP 승인 후 설정)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://xxxx.ngrok.io/auth/gmail/callback
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-notifications

# Firebase / Firestore
FIREBASE_PROJECT_ID=

# PostgreSQL (선택사항)
DATABASE_URL=postgresql://localhost:5432/ping_universe

# OpenRouter LLM
OPENROUTER_API_KEY=
