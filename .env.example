# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# Public base URL (ngrok/Cloudflare Tunnel in dev, real domain in prod)
BASE_URL=https://your-tunnel.ngrok.app

# --- Google Cloud / Firebase ---
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# Service account JSON used for Google Chat API + Pub/Sub + Firestore admin
GOOGLE_APPLICATION_CREDENTIALS=./keys/service-account.json
FIREBASE_PROJECT_ID=your-gcp-project-id

# --- Atlassian OAuth 3LO (Jira + Confluence) ---
# https://developer.atlassian.com/cloud/jira/platform/oauth-2-3lo-apps/
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=https://your-tunnel.ngrok.app/oauth/atlassian/callback

# --- Google OAuth (Gmail user consent) ---
# Separate from the service account. Used for per-user Gmail access.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-tunnel.ngrok.app/oauth/gmail/callback

# Gmail Pub/Sub topic (full resource name)
GMAIL_PUBSUB_TOPIC=projects/your-gcp-project-id/topics/gmail-notifications
# Optional: audience claim expected on Pub/Sub push JWT (defaults to BASE_URL)
GMAIL_PUBSUB_AUDIENCE=

# --- OpenRouter LLM (optional, for briefing summary) ---
OPENROUTER_API_KEY=
